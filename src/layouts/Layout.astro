---
// 引入全局样式，确保所有页面共享同一套 Tailwind 主题
import '../styles/global.css';
// 引入浮动按钮组件（暗色模式切换 + 返回顶部）
import FloatingButtons from '../components/FloatingButtons.astro';
// 引入配置文件
import { siteTitle } from '../config';
// 引入个人资料类型
import type { Profile } from '../types';

// 定义布局组件接收的属性
interface Props {
  // 页面标题，未传入时使用配置文件中的默认标题
  title?: string;
  // 当前用户资料，用于生成 description 等元信息
  profile: Profile;
}

// 从 props 中解构标题与资料，未传入时使用配置文件中的网站标题
const { title = siteTitle, profile } = Astro.props;
---

<!doctype html>
<!-- 页面根节点，语言设置为简体中文 -->
<html lang="zh-CN">
  <head>
    <!-- 字符编码与视口设置，适配移动端 including 刘海屏 -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <!-- SEO 描述，使用昵称拼接 -->
    <meta name="description" content={`${profile.nickname} 的个人动态`} />
    <!-- 站点图标 -->
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <!-- 页面标题 -->
    <title>{title}</title>
  </head>
  <!--  body 设置背景色，支持亮/暗色模式 -->
  <body class="bg-moments-bg dark:bg-moments-dark-bg">
    <!-- 内容容器：纯白背景，宽度自适应，与封面顶部贴边 -->
    <div class="mx-auto min-h-screen w-full max-w-[600px] bg-moments-card shadow-xl dark:bg-moments-dark-card">
      <slot />
    </div>

    <!-- 浮动按钮：暗色模式切换 + 返回顶部（fixed 定位） -->
    <FloatingButtons />

    <!-- 交互逻辑：从 public 目录加载，避免 Astro 脚本编译冲突 -->
    <!-- 加载顺序：模板生成器 → 动态加载/交互 → 管理员功能 -->
    <script src="/scripts/moment-template.js" defer></script>
    <script src="/scripts/moments.js" defer></script>
    <script src="/scripts/admin.js" defer></script>
  </body>
</html>
