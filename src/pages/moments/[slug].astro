---
import BaseLayout from '../../components/BaseLayout.astro';
import ImageGrid from '../../components/ImageGrid.astro';
import MusicPlayer from '../../components/MusicPlayer.astro';
import VideoPlayer from '../../components/VideoPlayer.astro';
import { siteProfile, siteMeta } from '../../config.ts';
import { getCollection, render } from 'astro:content';
import { formatRelativeTime, generateFixedRandom, normalizeDate, formatDate } from '../../utils';

export async function getStaticPaths() {
  const entries = await getCollection('moments');
  const publishedEntries = entries.filter((entry) => !entry.data.draft);
  return publishedEntries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const entry = Astro.props.entry;
const { Content } = await render(entry);

const momentData = {
  id: entry.id,
  date: formatDate(entry.data.date),
  Content: Content,
  images: entry.data.images || [],
  music: entry.data.music,
  video: entry.data.video,
  location: entry.data.location || '',
  author: { name: siteProfile.name, avatar: siteProfile.avatar },
};

const formattedDate = formatRelativeTime(momentData.date);
const seed = momentData.id;
const likeCount = generateFixedRandom(seed, 1, 50);
const commentCount = generateFixedRandom(seed + 'comment', 0, 20);

const entries = await getCollection('moments');
const sortedEntries = entries
  .filter((e) => !e.data.draft)
  .sort((a, b) => {
    const da = normalizeDate(a.data.date).getTime();
    const db = normalizeDate(b.data.date).getTime();
    return db - da;
  });
const currentIdx = sortedEntries.findIndex((e) => e.id === entry.id);
const prevEntry = currentIdx > 0 ? sortedEntries[currentIdx - 1] : null;
const nextEntry = currentIdx < sortedEntries.length - 1 ? sortedEntries[currentIdx + 1] : null;

const pageTitle = `${siteProfile.name}${siteMeta.titleSeparator}${entry.body?.slice(0, 20) || momentData.date}`;
---

<BaseLayout title={pageTitle}>
  <article class="moment-detail" data-moment-id={seed}>
    <div class="moment-detail-avatar">
      <img src={momentData.author.avatar} alt={momentData.author.name} loading="lazy" />
    </div>
    <div class="moment-detail-main">
      <span class="moment-detail-name">{momentData.author.name}</span>

      <div class="moment-detail-content">
        <Content />
      </div>

      {momentData.images && momentData.images.length > 0 && (
        <ImageGrid images={momentData.images} />
      )}

      {momentData.music && <MusicPlayer {...momentData.music} />}

      {momentData.video && <VideoPlayer {...momentData.video} />}

      <div class="moment-detail-meta">
        <span>{formattedDate}</span>
        {momentData.location && (
          <span class="moment-detail-location">
            <svg viewBox="0 0 24 24" width="12" height="12" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zM7 9c0-2.76 2.24-5 5-5s5 2.24 5 5c0 2.88-2.88 7.19-5 10-2.12-2.81-5-7.12-5-10z"/></svg>
            {momentData.location}
          </span>
        )}
      </div>

      <div class="moment-detail-stats">
        <span>
          <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
          {likeCount}
        </span>
        <span>
          <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor"><path d="M21.99 4c0-1.1-.89-2-1.99-2H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h14l4 4-.01-18z"/></svg>
          {commentCount}
        </span>
      </div>
    </div>
  </article>

  <nav class="moment-detail-nav">
    {prevEntry ? (
      <a href={`/moments/${prevEntry.id}`} class="moment-detail-nav-link">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/></svg>
        上一篇
      </a>
    ) : (
      <span class="moment-detail-nav-disabled">已经是第一篇</span>
    )}
    {nextEntry ? (
      <a href={`/moments/${nextEntry.id}`} class="moment-detail-nav-link">
        下一篇
        <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/></svg>
      </a>
    ) : (
      <span class="moment-detail-nav-disabled">已经是最后一篇</span>
    )}
  </nav>
</BaseLayout>
