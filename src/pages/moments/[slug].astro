---
/**
 * 动态详情页面
 */
import BaseLayout from '../../components/BaseLayout.astro';
import ImageGrid from '../../components/ImageGrid.astro';
import MusicPlayer from '../../components/MusicPlayer.astro';
import VideoPlayer from '../../components/VideoPlayer.astro';
import { siteProfile, siteMeta } from '../../config.ts';
import { getCollection } from 'astro:content';
import { formatRelativeTime, generateFixedRandom } from '../../utils';

const profile = siteProfile;

export async function getStaticPaths() {
  const entries = await getCollection('moments');
  const publishedEntries = entries.filter((entry) => !entry.data.draft);
  return publishedEntries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { slug } = Astro.params;
const entry = Astro.props.entry;

const dateStr = entry.data.date instanceof Date
  ? entry.data.date.toISOString().split('T')[0]
  : String(entry.data.date);

const moment = {
  id: entry.id,
  slug: entry.id,
  date: dateStr,
  content: entry.body || '',
  images: entry.data.images || [],
  music: entry.data.music,
  video: entry.data.video,
  location: entry.data.location || '',
  author: {
    name: profile.name,
    avatar: profile.avatar,
  },
};

const formattedDate = formatRelativeTime(moment.date);
const seed = moment.id || moment.slug || moment.date;
const likeCount = generateFixedRandom(seed, 1, 50);
const commentCount = generateFixedRandom(seed + 'comment', 0, 20);

const entries = await getCollection('moments');
const currentIndex = entries.findIndex((e) => e.id === entry.id);
const prevEntry = entries[currentIndex - 1] || null;
const nextEntry = entries[currentIndex + 1] || null;
const prev = prevEntry ? { slug: prevEntry.id } : null;
const next = nextEntry ? { slug: nextEntry.id } : null;

const pageTitle = `${profile.name}${siteMeta.titleSeparator}${moment.content.slice(0, 20) || moment.date}`;
---

<BaseLayout title={pageTitle}>
  <article class="moment" data-moment-id={seed}>
    <div class="avatar-container">
      <img class="avatar" src={moment.author.avatar} alt={moment.author.name} loading="lazy" />
    </div>

    <div class="body">
      <span class="author">{moment.author.name}</span>

      {moment.content && (
        <p class="content">{moment.content.trim()}</p>
      )}

      {moment.images && moment.images.length > 0 && (
        <ImageGrid images={moment.images} />
      )}

      {moment.music && <MusicPlayer {...moment.music} />}

      {moment.video && <VideoPlayer url={moment.video.url} cover={moment.video.cover} />}

      <div class="meta">
        <span class="time">
          {formattedDate}
          {moment.location && <span class="location"> · {moment.location}</span>}
        </span>

        <div class="actions">
          <button
            class="action-btn like-btn"
            type="button"
            aria-label="点赞"
            data-like-count={likeCount}
            data-moment-id={seed}
          >
            <svg class="icon" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
              <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"></path>
            </svg>
            <span class="count">{likeCount}</span>
          </button>

          <button
            class="action-btn comment-btn"
            type="button"
            aria-label="评论"
            data-comment-count={commentCount}
          >
            <svg class="icon" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
              <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path>
            </svg>
            <span class="count">{commentCount}</span>
          </button>
        </div>
      </div>
    </div>
  </article>

  <nav class="pagination">
    {prev ? (
      <a href={`/moments/${prev.slug}`} class="pagination-prev">上一页</a>
    ) : (
      <span class="pagination-placeholder">上一页</span>
    )}

    {next ? (
      <a href={`/moments/${next.slug}`} class="pagination-next">下一页</a>
    ) : (
      <span class="pagination-placeholder">下一页</span>
    )}
  </nav>
</BaseLayout>
