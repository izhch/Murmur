---
/**
 * 归档列表页
 */
import BaseLayout from '../components/BaseLayout.astro';
import { siteMeta } from '../config.ts';
import { getCollection } from 'astro:content';

const entries = await getCollection('moments');
const publishedEntries = entries.filter((entry) => !entry.data.draft);

const groupedMoments = publishedEntries.reduce((acc, entry) => {
  const date = entry.data.date instanceof Date
    ? entry.data.date
    : new Date(entry.data.date);
  const year = date.getFullYear();
  const month = String(date.getMonth() + 1).padStart(2, '0');
  const key = `${year}-${month}`;
  if (!acc[key]) acc[key] = [];
  acc[key].push(entry);
  return acc;
}, {} as Record<string, typeof entries>);

const sortedGroups = Object.entries(groupedMoments)
  .sort((a, b) => b[0].localeCompare(a[0]))
  .map(([key, items]) => {
    const [year, month] = key.split('-');
    return {
      key,
      year,
      month,
      count: items.length,
    };
  });
---

<BaseLayout title={`归档${siteMeta.titleSeparator}${siteMeta.siteName}`}>
  <main class="archive-page">
    <div class="archive-list">
      {sortedGroups.map((group) => (
        <a href={`/archive/${group.key}`} class="archive-item">
          <span class="archive-date">{group.year} / {group.month}</span>
          <span class="archive-count">{group.count}</span>
        </a>
      ))}
    </div>
  </main>
</BaseLayout>

<style>
  .archive-page { padding: 60px 80px; }
  .archive-list { display: flex; flex-direction: column; gap: 0; max-width: 420px; margin: 0 auto; }
  .archive-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 8px;
    font-size: 16px;
    font-weight: 300;
    letter-spacing: 0.05em;
    color: var(--text_color_primary);
    border-bottom: 1px solid var(--splitline_color);
    text-decoration: none;
    transition: color 0.3s ease, padding-left 0.3s ease, padding-right 0.3s ease;
    font-variant-numeric: tabular-nums;
  }
  .archive-date { font-family: 'SF Mono', 'Menlo', monospace; }
  .archive-count { color: var(--text_color_tertiary); font-family: 'SF Mono', 'Menlo', monospace; }
  .archive-item:hover { color: var(--text_color_highlight); padding-left: 16px; padding-right: 0; }
  .archive-item:hover .archive-count { color: var(--text_color_highlight); }

  @media screen and (max-width: 550px) {
    .archive-page { padding: 40px 32px; }
    .archive-item { font-size: 15px; padding: 18px 4px; }
  }
</style>
