---
// 404 页面：处理未匹配的路由
// 特殊处理：兼容老的 /content/{id} URL，重定向到新的 /content/?id={id} 形式

import Layout from '../layouts/Layout.astro';
import CoverBanner from '../components/CoverBanner.astro';
import { profile } from '../config';
---

<Layout profile={profile}>
  <CoverBanner profile={profile} />

  <main class="pt-[32px] sm:pt-[36px] md:pt-[40px]" id="moments-container">
    <div class="loading-indicator py-6 text-center">
      <span class="loading-breath text-[14px] text-moments-sub dark:text-moments-dark-sub">正在加载...</span>
    </div>
    <div class="not-found-message hidden py-12 text-center">
      <p class="text-[16px] text-moments-sub dark:text-moments-dark-sub">页面不存在</p>
      <a href="/" class="mt-3 inline-block text-[14px] text-moments-link dark:text-moments-dark-link">返回首页</a>
    </div>
  </main>
</Layout>

<script is:inline>
  // 客户端路由处理：
  // - 老 URL /content/{id} → 重定向到新形式 /?id={id}
  // - 其他路径 → 显示 404 提示
  (function () {
    var path = window.location.pathname;
    var match = path.match(/^\/content\/([^\/]+)\/?$/);
    if (match) {
      // 老的详情页 URL 形式，重定向到新形式
      window.location.replace('/?id=' + encodeURIComponent(decodeURIComponent(match[1])));
      return;
    }
    // 其他路径：显示 404
    var loading = document.querySelector('.loading-indicator');
    var notFound = document.querySelector('.not-found-message');
    if (loading) loading.style.display = 'none';
    if (notFound) notFound.classList.remove('hidden');
  })();
</script>
