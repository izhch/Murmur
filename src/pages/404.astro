---
import BaseLayout from '../components/BaseLayout.astro';
import ProfileHeader from '../components/ProfileHeader.astro';
import { siteMeta } from '../config.ts';
---

<BaseLayout title={`404${siteMeta.titleSeparator}${siteMeta.siteName}`}>
  <ProfileHeader />
  <main id="error-page">
    <div class="error-icon">
      <svg viewBox="0 0 200 200" width="120" height="120" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="100" cy="100" r="80" stroke="currentColor" stroke-width="2" stroke-dasharray="8 4" opacity="0.3"/>
        <text x="100" y="90" text-anchor="middle" fill="currentColor" font-size="48" font-weight="300" font-family="HarmonyOS Sans, sans-serif">404</text>
        <text x="100" y="120" text-anchor="middle" fill="currentColor" font-size="14" font-weight="300" font-family="HarmonyOS Sans, sans-serif">页面走丢了</text>
      </svg>
    </div>
    <a href="/" class="error-back-link">返回首页</a>
  </main>
</BaseLayout>
