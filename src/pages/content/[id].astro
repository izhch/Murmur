---
// 动态详情页（纯动态版本）
// 页面为空壳，内容由 moments.js 从 Worker API 加载
// getStaticPaths 仍从 markdown 文件生成静态路径，保证已有动态的 URL 可访问

// 引入布局与封面组件
import Layout from '../../layouts/Layout.astro';
import CoverBanner from '../../components/CoverBanner.astro';
import { profile } from '../../config';
import type { BlogModule } from '../../types';

// 从 src/content/*.md 生成静态路径（仅用于 URL 生成，不渲染内容）
export function getStaticPaths() {
  const posts = import.meta.glob('../../content/*.md', { eager: true }) as Record<string, BlogModule>;
  return Object.keys(posts).map((path) => ({
    params: { id: path.split('/').pop()?.replace(/\.md$/, '') || '' },
  }));
}
---

<Layout profile={profile}>
  <!-- 封面横幅 -->
  <CoverBanner profile={profile} />

  <!-- 详情页主内容区：内容由 JS 从 Worker API 动态加载 -->
  <main class="pt-[32px] sm:pt-[36px] md:pt-[40px]" id="moments-container">
    <!-- 加载中提示 -->
    <div class="loading-indicator py-6 text-center">
      <span class="loading-breath text-[14px] text-moments-sub dark:text-moments-dark-sub">正在加载...</span>
    </div>
  </main>
</Layout>
