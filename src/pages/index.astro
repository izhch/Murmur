---
// 主页：展示朋友圈动态列表（纯动态版本）
// 内容由 moments.js 从 Worker API 加载，通过 MomentTemplate 渲染

// 引入布局、封面组件与配置
import Layout from '../layouts/Layout.astro';
import CoverBanner from '../components/CoverBanner.astro';
import { profile, AMAP_KEY, API_BASE } from '../config';
---

<Layout profile={profile}>
  <!-- 封面横幅 -->
  <CoverBanner profile={profile} />

  <!-- 动态列表容器：内容由 JS 从 Worker API 动态加载 -->
  <main
    class="pt-[32px] sm:pt-[36px] md:pt-[40px]"
    id="moments-container"
    data-page-size={5}
  >
    <!-- 加载中提示：首屏由 JS 动态插入卡片前显示 -->
    <div class="loading-indicator py-6 text-center">
      <span class="loading-breath text-[14px] text-moments-sub dark:text-moments-dark-sub">正在加载...</span>
    </div>
  </main>

  <!-- 全局配置变量注入（直接内联服务端值到客户端脚本） -->
  <script is:inline define:vars={{ AMAP_KEY, API_BASE }}>
    window.__CONFIG__ = {
      amapKey: AMAP_KEY,
      apiBase: API_BASE
    };
  </script>
</Layout>
