---
import BaseLayout from '../components/BaseLayout.astro';
import ProfileHeader from '../components/ProfileHeader.astro';
import Lightbox from '../components/Lightbox.astro';
import MomentItem from '../components/MomentItem.astro';
import { siteMeta, siteProfile } from '../config.ts';
import { getCollection, render } from 'astro:content';
import { formatDate } from '../utils.ts';

const INITIAL_PER_PAGE = 5;
const LOAD_MORE_STEP = 5;

const entries = await getCollection('moments');
const publishedEntries = entries.filter((entry) => !entry.data.draft);

const sortedEntries = publishedEntries.sort((a, b) => {
  return new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
});

const allMoments = await Promise.all(sortedEntries.map(async (entry) => {
  const { Content } = await render(entry);

  return {
    id: entry.id,
    date: formatDate(entry.data.date),
    content: entry.body || '',
    Content: Content,
    images: entry.data.images || [],
    music: entry.data.music,
    video: entry.data.video,
    location: entry.data.location || '',
    author: { name: siteProfile.name, avatar: siteProfile.avatar },
  };
}));

const totalCount = allMoments.length;
const hasMore = totalCount > INITIAL_PER_PAGE;
---

<BaseLayout title={siteMeta.siteName}>
  <ProfileHeader />

  <main id="posts" data-step={LOAD_MORE_STEP} data-total={totalCount}>
    {allMoments.map((moment, idx) => (
      <MomentItem moment={moment} class={idx >= INITIAL_PER_PAGE ? 'moment-hidden' : ''} />
    ))}
  </main>

  <footer id="navigation">
    {hasMore ? (
      <div id="autoload">加载更多</div>
    ) : (
      <div id="autoload" style="cursor: default;">—— 已加载全部动态 ——</div>
    )}
  </footer>

  <Lightbox />
</BaseLayout>
