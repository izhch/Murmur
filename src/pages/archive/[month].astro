---
/**
 * 归档详情页面
 */
import BaseLayout from '../../components/BaseLayout.astro';
import MomentItem from '../../components/MomentItem.astro';
import { siteProfile, siteMeta } from '../../config.ts';
import { getCollection } from 'astro:content';

const profile = siteProfile;

export async function getStaticPaths() {
  const entries = await getCollection('moments');
  const publishedEntries = entries.filter((entry) => !entry.data.draft);
  const months = new Set<string>();
  publishedEntries.forEach((entry) => {
    const date = entry.data.date instanceof Date
      ? entry.data.date
      : new Date(entry.data.date);
    const year = date.getFullYear();
    const month = String(date.getMonth() + 1).padStart(2, '0');
    months.add(`${year}-${month}`);
  });
  return Array.from(months).map((month) => ({
    params: { month },
  }));
}

const { month } = Astro.params;
const [year, monthNum] = (month || '').split('-');
const monthNames = ['一月', '二月', '三月', '四月', '五月', '六月', '七月', '八月', '九月', '十月', '十一月', '十二月'];

const entries = await getCollection('moments');
const publishedEntries = entries.filter((entry) => !entry.data.draft);
const filteredMoments = publishedEntries.filter((entry) => {
  const date = entry.data.date instanceof Date
    ? entry.data.date
    : new Date(entry.data.date);
  return date.getFullYear() === parseInt(year) && date.getMonth() + 1 === parseInt(monthNum);
});

const moments = filteredMoments.map((entry) => {
  const dateStr = entry.data.date instanceof Date
    ? entry.data.date.toISOString().split('T')[0]
    : String(entry.data.date);

  return {
    id: entry.slug,
    slug: entry.slug,
    date: dateStr,
    title: entry.data.title || '',
    content: entry.body || '',
    images: entry.data.images || [],
    music: entry.data.music,
    video: entry.data.video,
    location: entry.data.location || '',
    author: {
      name: profile.name,
      avatar: profile.avatar,
    },
  };
});

const displayTitle = `${year}年${monthNames[parseInt(monthNum) - 1]}`;
---

<BaseLayout title={`${displayTitle}${siteMeta.titleSeparator}${siteMeta.siteName}`}>
  <main style="text-align: center; padding: var(--spacing_xxxl, 30px) var(--spacing_l, 16px) var(--spacing_l, 16px); border-bottom: 1px solid var(--splitline_color, #f2f2f2);">
    <a href="/archive" class="back-link">
      <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" style="display: inline-block; vertical-align: middle;">
        <path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z" />
      </svg>
      返回归档
    </a>
    <h1 style="font-size: 28px; font-weight: 600; color: var(--text_color_primary); margin: 8px 0;">{displayTitle}</h1>
    <p style="font-size: var(--font_size_short, 14px); color: var(--text_color_secondary, #b2b2b2);">共 {moments.length} 条动态</p>
  </main>

  <main style="padding-bottom: var(--spacing_xxl, 25px);">
    {moments.map((m) => (
      <MomentItem moment={m} />
    ))}

    {moments.length === 0 && (
      <div style="text-align: center; padding: 60px 20px; color: var(--text_color_secondary, #b2b2b2); font-size: var(--font_size_short, 14px);">
        <p>该月份暂无动态</p>
      </div>
    )}
  </main>
</BaseLayout>
