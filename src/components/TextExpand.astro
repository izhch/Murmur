---
/**
 * 文字展开/收起：短文本直接显示，长文本（>150字）启用展开收起
 */
interface Props {
  content: string
}

const { content } = Astro.props
const trimmed = content.trim()
const MAX_LEN = 150
const isLong = trimmed.length > MAX_LEN
---

{isLong ? (
  <span class="more-area">
    <span class="more-content">{trimmed}</span>
    <span class="more-ellipsis">{trimmed.slice(0, MAX_LEN)}...</span>
    <button class="more-link more" type="button">全文</button>
    <button class="more-link less" type="button">收起</button>
  </span>
) : (
  <span>{trimmed}</span>
)}
