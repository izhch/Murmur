---
// 动态卡片主组件：整合头像、正文、图片/音乐/视频、时间与菜单

// 引入子组件与类型
import Avatar from './Avatar.astro';
import MenuPopover from './MenuPopover.astro';
import ImageGrid from './ImageGrid.astro';
import MusicPlayer from './MusicPlayer.astro';
import VideoPlayer from './VideoPlayer.astro';
import PasswordProtect from './PasswordProtect.astro';
import type { Moment } from '../types';

// 重新导出 Moment 类型，方便外部使用
export type { Moment } from '../types';

// 定义动态卡片属性
interface Props {
  // 单条动态数据
  moment: Moment;
  // 是否为最后一条，控制分隔线显示
  isLast?: boolean;
}

// 解构 props，并取出 Markdown 渲染组件
const { moment, isLast = false } = Astro.props;
const BodyContent = moment.content.Content;
---

<!-- 单条动态卡片：设置内边距，绑定动态 id -->
<article class="px-[20px] pt-[12px] sm:px-[25px] sm:pt-[15px]" data-moment-id={moment.id}>
  <div class="flex gap-[12px] sm:gap-[14px]">
    <!-- 左侧头像 -->
    <Avatar src={moment.avatar} size={36} className="shrink-0" />

    <div class="min-w-0 flex-1">
      <!-- 昵称：使用链接色，比头像顶部略低，有密码保护时显示锁图标 -->
      <p class="pt-[2px] text-[16px] font-medium leading-[24px] text-moments-link dark:text-moments-dark-link flex items-center gap-1">
        {moment.author}
        {moment.password_hash && (
          <svg class="w-[18px] h-[18px] text-moments-link dark:text-moments-dark-link" viewBox="0 0 256 256" xmlns="http://www.w3.org/2000/svg">
            <g>
              <!-- 锁钩：描边样式 -->
              <path d="m160,96l0,-18c0,-16.63 -14.26001,-30 -32,-30s-32,13.37 -32,30l0,18"
                stroke-width="26" stroke-linejoin="round" stroke-linecap="round"
                stroke="currentColor" fill="none" />
              <!-- 锁体：填充样式 -->
              <path d="m176,208l-96,0a32,32 0 0 1 -32,-32l0,-48a32,32 0 0 1 32,-32l96,0a32,32 0 0 1 32,32l0,48a32,32 0 0 1 -32,32z"
                fill="currentColor" />
            </g>
          </svg>
        )}
      </p>

      <!-- 内容区域：有密码保护时默认隐藏，密码正确后显示 -->
      <div class:list={['moment-content-wrapper', moment.password_hash && 'moment-content-hidden']} data-moment-id={moment.id} data-content-wrapper>
        <!-- 正文内容：Markdown 渲染，自动换行，支持展开/收起 -->
        {BodyContent && (
          <div class="moment-body-container mt-[3px]">
            <div
              class="moment-body text-[15px] leading-[24px] text-moments-text dark:text-moments-dark-text break-words sm:text-[16px]"
              style={moment.needsCollapse ? 'max-height: 120px; overflow: hidden; transition: max-height 0.3s ease;' : undefined}
            >
              <BodyContent />
            </div>
            <!-- 展开/收起按钮：默认隐藏，JS 根据内容高度动态显示 -->
            <button
              class:list={[
                'expand-btn mt-1.5 flex h-6 items-center text-[13px] text-moments-link dark:text-moments-dark-link',
                !moment.needsCollapse && 'hidden',
              ]}
            >
              <span class="expand-text">展开</span>
              <svg class="expand-icon ml-0.5 h-3 w-3 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M6 9l6 6 6-6" />
              </svg>
            </button>
          </div>
        )}

        <!-- 根据类型渲染对应媒体组件 -->
        {moment.content.type === 'images' && (
          <ImageGrid images={moment.content.images} />
        )}
        {moment.content.type === 'music' && (
          <MusicPlayer
            title={moment.content.title}
            artist={moment.content.artist}
            cover={moment.content.cover}
            src={moment.content.src}
          />
        )}
        {moment.content.type === 'video' && (
          <VideoPlayer
            src={moment.content.src}
            duration={moment.content.duration}
          />
        )}
      </div>

      <!-- 密码保护遮罩层：放在内容区域下方、时间信息上方 -->
      {moment.password_hash && (
        <PasswordProtect momentId={moment.id} passwordHash={moment.password_hash} />
      )}

      <!-- 时间信息：始终显示，不受密码保护影响 -->
      <!-- 有密码保护时菜单初始隐藏，解锁后由 JS 控制显示 -->
      <div class:list={['py-3.5 flex items-center justify-between']}>
        <div class="flex min-w-0 items-center gap-2 whitespace-nowrap text-[14px] leading-[22px] text-moments-sub dark:text-moments-dark-sub">
          <span class="shrink-0 relative-time" data-date={moment.createdAt}>{moment.createdAt}</span>
          {moment.location && (
            <span class="truncate">{moment.location}</span>
          )}
        </div>

        <!-- 赞/评论弹出菜单：有密码保护时初始隐藏，解锁后显示 -->
        <div class:list={['shrink-0', moment.password_hash && 'hidden']} data-menu-wrapper>
          <MenuPopover momentId={moment.id} />
        </div>
      </div>
    </div>
  </div>
</article>

<!-- 分隔线：除最后一条外显示，左侧留出头像位置 -->
{!isLast && <div class="ml-[68px] mr-[20px] h-px bg-moments-divider dark:bg-moments-dark-divider sm:ml-[75px] sm:mr-[25px]"></div>}
