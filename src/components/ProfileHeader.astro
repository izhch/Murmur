---
/**
 * 个人资料头部：封面、头像、昵称、签名、菜单
 */
import { siteProfile, siteMeta, menuItems } from '../config.ts';

interface Props {
  profile?: { name: string; avatar: string; cover: string; signature: string };
}

const { profile = siteProfile } = Astro.props;
---

<header class="profile-header">
  <div class="cover-wrap">
    <img class="cover" src={profile.cover} alt="封面" />

    <button class="menu-btn" id="menuBtn" aria-label="菜单">
      <span class="menu-line"></span>
      <span class="menu-line"></span>
      <span class="menu-line"></span>
    </button>

    <a href="/" class="cover-profile">
      <span class="cover-nickname">{siteMeta.siteName}</span>
      <img class="cover-avatar" src={profile.avatar} alt={profile.name} />
    </a>

    <div class="menu-dropdown" id="menuDropdown">
      <button class="menu-close" id="menuClose" aria-label="关闭菜单">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
          <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" />
        </svg>
      </button>

      <div class="menu-content">
        {menuItems.map((item) => (
          <a href={item.href} class="menu-item">{item.label}</a>
        ))}
      </div>
    </div>
  </div>

  <div class="signature-wrap">
    <p class="signature">{profile.signature}</p>
  </div>
</header>

<script is:inline>
(function () {
  var menuBtn = document.getElementById('menuBtn');
  var menuDropdown = document.getElementById('menuDropdown');
  var menuClose = document.getElementById('menuClose');
  if (!menuBtn || !menuDropdown) return;
  menuBtn.addEventListener('click', function (e) { e.stopPropagation(); menuDropdown.classList.add('open'); });
  if (menuClose) menuClose.addEventListener('click', function (e) { e.stopPropagation(); menuDropdown.classList.remove('open'); });
  document.addEventListener('click', function (e) { if (!menuDropdown.contains(e.target) && !menuBtn.contains(e.target)) menuDropdown.classList.remove('open'); });
})();
</script>

<style>
  .profile-header { position: relative; background: var(--background_color_container); max-width: var(--page_max_width_container); margin: 0 auto; }

  .cover-wrap { position: relative; width: 100%; height: var(--cover_height); overflow: visible; background: var(--background_color_block); }
  .cover { width: 100%; height: 100%; object-fit: cover; display: block; }

  .menu-btn { position: absolute; top: var(--spacing_l); right: var(--spacing_l); z-index: 100; width: 32px; height: 32px; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 5px; padding: var(--spacing_xs); background: transparent; border: none; cursor: pointer; }
  .menu-line { display: block; width: 20px; height: 2px; background: var(--text_color_reversal); border-radius: 1px; }

  .cover-profile { position: absolute; right: var(--spacing_l); bottom: -20px; display: flex; flex-direction: row; align-items: flex-end; gap: var(--spacing_m); z-index: 50; width: auto; flex-wrap: nowrap; }
  .cover-nickname { font-size: var(--cover_nickname_size); font-weight: 600; color: var(--text_color_reversal); text-shadow: 0 1px 4px rgba(0, 0, 0, 0.5); padding-bottom: var(--cover_nickname_bottom_padding); white-space: nowrap; }
  .cover-avatar { width: var(--cover_avatar_size); height: var(--cover_avatar_size); border-radius: var(--cover_avatar_radius); object-fit: cover; border: 2px solid var(--text_color_reversal); box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15); display: block; }

  .menu-dropdown { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: var(--background_color_container); z-index: 200; opacity: 0; visibility: hidden; transform: translateY(-8px) scale(0.98); transition: opacity 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94), transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94); display: flex; flex-direction: column; }
  .menu-dropdown.open { opacity: 1; visibility: visible; transform: translateY(0) scale(1); }
  .menu-close { position: absolute; top: var(--spacing_l); right: var(--spacing_l); width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; background: transparent; border: none; cursor: pointer; color: var(--text_color_tertiary); transition: color 0.3s ease, transform 0.3s ease; }
  .menu-close:hover { color: var(--text_color_primary); transform: rotate(90deg); }
  .menu-content { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 36px; padding-top: 60px; }
  .menu-dropdown.open .menu-item { opacity: 1; transform: translateY(0); }
  .menu-item { position: relative; font-size: 22px; font-weight: 300; letter-spacing: 0.05em; color: var(--text_color_primary); text-decoration: none; transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94); padding: 10px 28px; opacity: 0.7; transform: translateY(-10px); }
  .menu-dropdown.open .menu-item { opacity: 1; transform: translateY(0); }
  .menu-item::after { content: ''; position: absolute; bottom: 4px; left: 50%; width: 0; height: 1px; background: var(--text_color_highlight); transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94); transform: translateX(-50%); }
  .menu-item:hover { color: var(--text_color_highlight); }
  .menu-item:hover::after { width: calc(100% - 56px); }

  .signature-wrap { padding: var(--spacing_l); text-align: right; padding-top: var(--signature_top_padding); }
  .signature { font-size: var(--signature_font_size); color: var(--signature_color); margin: 0; line-height: 1.5; }

  @media screen and (max-width: 680px) {
    .cover-wrap { height: auto; aspect-ratio: 680 / 325; }
    .cover-nickname { font-size: var(--font_size); }
    .cover-avatar { width: 56px; height: 56px; }
    .signature-wrap { padding: var(--spacing_m); padding-top: 28px; }
    .signature { font-size: var(--font_size_short); }
  }

  @media screen and (max-width: 480px) {
    .cover-nickname { font-size: var(--font_size); }
    .cover-avatar { width: 50px; height: 50px; }
    .signature-wrap { padding-top: 24px; }
    .signature { font-size: var(--font_size_tall); }
  }
</style>
