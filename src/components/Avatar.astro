---
// 头像组件：用于动态卡片左侧的用户头像
// 支持自定义尺寸、圆角与额外类名

// 定义头像组件属性
interface Props {
  // 头像图片地址
  src: string;
  // 图片 alt 文本，默认空字符串
  alt?: string;
  // 头像尺寸（宽高相同），默认 40px
  size?: number;
  // 圆角类名，默认 5px 圆角
  rounded?: string;
  // 额外 Tailwind 类名，用于外边距等
  className?: string;
}

// 从 props 中解构并设置默认值
const { src, alt = '', size = 40, rounded = 'rounded-[5px]', className = '' } = Astro.props;
---

<!-- 头像图片：按 size 设置固定宽高，懒加载，占位背景 -->
<img
  src={src}
  alt={alt}
  class={`${rounded} object-cover bg-moments-divider ${className}`}
  style={`width:${size}px;height:${size}px;`}
  loading="lazy"
/>
