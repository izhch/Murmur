---
import { siteMeta, siteProfile } from '../config.ts';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = siteMeta.siteName,
  description = siteMeta.description,
} = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1.0,maximum-scale=1.0,minimum-scale=1.0,user-scalable=no" />
  <meta name="description" content={description} />
  <meta name="author" content={siteProfile.name} />
  <title>{title}</title>
  <link rel="preload" href="/font/HarmonyOS_Sans_regular.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="manifest" href="/manifest.json" />
  <meta name="theme-color" content="#ffffff" />
  <script is:inline>
    // 暗色模式自动检测
    if (window.matchMedia) {
      let darkModeMedia = window.matchMedia('(prefers-color-scheme: dark)');
      let darkModeProcessing = bool => bool ? document.documentElement.classList.add('darkmode') : document.documentElement.classList.remove('darkmode');
      if (darkModeMedia.matches) darkModeProcessing(true);
      darkModeMedia.addEventListener('change', e => {
        darkModeProcessing(e.matches);
      });
    }
  </script>
</head>

<body>
  <noscript>请启用 JavaScript 以获得最佳体验</noscript>
  <div id="container">
    <slot />
  </div>

  <!-- Misc: 暗色切换 + 返回顶部 -->
  <div id="misc">
    <div id="appearance" title="切换暗色模式"></div>
    <div id="totop" title="返回顶部">返回顶部</div>
  </div>

  <script is:inline>
    (function() {
      // ===== Viewer =====
      var viewer = {
        el: document.getElementById('viewer'),
        back: document.querySelector('#viewer .back'),
        imgFigure: document.querySelector('#viewer .back figure.image'),
        count: document.querySelector('#viewer .front .count'),
        gallery: { list: [], index: 0 }
      };

      function viewerShow(idx, list) {
        viewer.gallery.list = list;
        viewer.gallery.index = ((idx % list.length) + list.length) % list.length;
        var img = viewer.imgFigure.querySelector('img');
        if (!img) {
          img = document.createElement('img');
          viewer.imgFigure.appendChild(img);
        }
        img.src = list[viewer.gallery.index];
        if (viewer.count) viewer.count.textContent = (viewer.gallery.index + 1) + '/' + list.length;
        viewer.el.classList.add('show');
        document.documentElement.classList.add('fullscreen');
      }

      function viewerHide() {
        viewer.el.classList.remove('show');
        document.documentElement.classList.remove('fullscreen');
      }

      function viewerPrev() {
        if (viewer.gallery.list.length > 1) {
          viewerShow(viewer.gallery.index - 1, viewer.gallery.list);
        }
      }

      function viewerNext() {
        if (viewer.gallery.list.length > 1) {
          viewerShow(viewer.gallery.index + 1, viewer.gallery.list);
        }
      }

      // Viewer 事件委托
      document.addEventListener('click', function(e) {
        var t = e.target;

        // 图片点击打开 viewer
        var img = t.closest('img[data-images]');
        if (img) {
          try {
            var imgs = JSON.parse(decodeURIComponent(img.getAttribute('data-images') || '[]'));
            if (imgs.length) viewerShow(parseInt(img.getAttribute('data-index') || '0', 10), imgs);
          } catch(err) {}
          return;
        }

        // 照片墙图片点击
        var photoImg = t.closest('#photoWall img');
        if (photoImg) {
          var allImgs = [];
          var idx = 0;
          var photos = document.querySelectorAll('#photoWall img');
          for (var i = 0; i < photos.length; i++) {
            allImgs.push(photos[i].src);
            if (photos[i] === photoImg) idx = i;
          }
          if (allImgs.length) viewerShow(idx, allImgs);
          return;
        }

        // Viewer 内部按钮
        var viewerEl = t.closest('#viewer');
        if (viewerEl) {
          var action = t.closest('[data-action]');
          if (action) {
            var act = action.getAttribute('data-action');
            if (act === 'close') viewerHide();
            if (act === 'prev') viewerPrev();
            if (act === 'next') viewerNext();
            return;
          }
          // 点击背景或空白处关闭
          viewerHide();
          return;
        }
      });

      document.addEventListener('keydown', function(e) {
        if (!viewer.el.classList.contains('show')) return;
        if (e.key === 'Escape') { viewerHide(); return; }
        if (e.key === 'ArrowLeft') viewerPrev();
        if (e.key === 'ArrowRight') viewerNext();
      });

      // ===== Fun Box =====
      function closeAllFunBox() {
        document.querySelectorAll('#posts > article.funboxshow').forEach(function(art) {
          art.classList.remove('funboxshow');
        });
      }

      document.addEventListener('click', function(e) {
        var t = e.target;

        var funIco = t.closest('.fun-ico');
        if (funIco) {
          var article = funIco.closest('article');
          if (article) {
            var isOpen = article.classList.contains('funboxshow');
            closeAllFunBox();
            if (!isOpen) article.classList.add('funboxshow');
          }
          return;
        }

        var funBox = t.closest('.fun-box');
        if (funBox) {
          var likeBtn = t.closest('.fun-btn.like');
          if (likeBtn) {
            var isLiked = likeBtn.classList.toggle('liked');
            likeBtn.textContent = isLiked ? '取消' : '赞';
            closeAllFunBox();
            return;
          }
          var commentBtn = t.closest('.fun-btn.comment');
          if (commentBtn) {
            closeAllFunBox();
            return;
          }
          return;
        }

        closeAllFunBox();
      });

      // ===== Misc (暗色切换 + 返回顶部) =====
      var misc = document.getElementById('misc');
      if (misc) {
        window.addEventListener('scroll', function() {
          misc.classList.toggle('show', window.scrollY > 200);
        }, { passive: true });
      }

      var appearance = document.getElementById('appearance');
      if (appearance) {
        appearance.addEventListener('click', function() {
          document.documentElement.classList.toggle('darkmode');
        });
      }

      var totop = document.getElementById('totop');
      if (totop) {
        totop.addEventListener('click', function() {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
      }

      // ===== Bar 下拉菜单 =====
      var barDropdown = document.getElementById('bar-dropdown');
      var bannerInfo = document.getElementById('banner-info');
      var bannerSubinfo = document.getElementById('banner-subinfo');
      if (barDropdown) {
        document.addEventListener('click', function(e) {
          var userBtn = e.target.closest('.bar-op > li.user');
          if (userBtn) {
            var isOpen = barDropdown.classList.toggle('show');
            if (bannerInfo) bannerInfo.style.visibility = isOpen ? 'hidden' : '';
            if (bannerSubinfo) bannerSubinfo.style.visibility = isOpen ? 'hidden' : '';
            return;
          }
          var closeBtn = e.target.closest('[data-action="close-menu"]');
          if (closeBtn) {
            barDropdown.classList.remove('show');
            if (bannerInfo) bannerInfo.style.visibility = '';
            if (bannerSubinfo) bannerSubinfo.style.visibility = '';
            return;
          }
        });
      }

      // ===== 展开收起 =====
      document.addEventListener('click', function(e) {
        var btn = e.target.closest('.more-btn');
        if (btn) {
          var area = btn.closest('.more-area');
          if (area) {
            area.classList.toggle('complete');
          }
          return;
        }
      });

      // ===== 查看更多 =====
      var autoload = document.getElementById('autoload');
      if (autoload) {
        function handleAutoload() {
          var feed = document.getElementById('posts');
          if (!feed) return;
          var step = parseInt(feed.getAttribute('data-step') || '5', 10);
          var hiddenItems = document.querySelectorAll('.moment-hidden');

          autoload.classList.add('wait');
          autoload.innerHTML = '<svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" style="animation: g-animation-wait-circle 1s linear infinite; vertical-align: middle;"><path d="M12 2a10 10 0 0 1 10 10h-3a7 7 0 0 0-7-7V2z"/></svg>';

          setTimeout(function() {
            for (var i = 0; i < step && i < hiddenItems.length; i++) {
              hiddenItems[i].classList.remove('moment-hidden');
            }

            var remaining = document.querySelectorAll('.moment-hidden').length;
            autoload.classList.remove('wait');
            autoload.textContent = '加载更多';
            if (remaining === 0) {
              autoload.textContent = '—— 已加载全部动态 ——';
              autoload.style.cursor = 'default';
              autoload.removeEventListener('click', handleAutoload);
            }
          }, 800);
        }
        autoload.addEventListener('click', handleAutoload);
      }
      // 图片淡入：立即显示已加载的图片，为 lazy 图片添加 intersection observer
      document.querySelectorAll('img').forEach(function(img) {
        if (img.complete && img.naturalWidth > 0) {
          img.classList.add('loaded');
        } else if (img.getAttribute('loading') === 'lazy') {
          // lazy 图片：进入视口时自动添加 loaded
          var observer = new IntersectionObserver(function(entries) {
            entries.forEach(function(entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add('loaded');
                observer.unobserve(entry.target);
              }
            });
          }, { rootMargin: '50px' });
          observer.observe(img);
          // 同时监听 load/error 事件作为后备
          img.addEventListener('load', function() { img.classList.add('loaded'); });
          img.addEventListener('error', function() { img.classList.add('loaded'); });
        } else {
          img.addEventListener('load', function() { img.classList.add('loaded'); });
          img.addEventListener('error', function() { img.classList.add('loaded'); });
        }
      });
    })();
  </script>
</body>
</html>
