---
interface Props {
  title: string
  artist: string
  url: string
  cover?: string
}

const { title, artist, url, cover } = Astro.props
---

<div class="music-player" data-music-url={url}>
  <div class="music-cover">
    {cover ? (
      <img src={cover} alt={title} loading="lazy" class="music-cover-img" data-cover-url={cover} />
    ) : (
      <div class="music-cover-placeholder"></div>
    )}
  </div>
  <div class="music-info-gradient">
    <div class="music-info">
      <div class="music-title">{title}</div>
      <div class="music-artist">{artist}</div>
    </div>
    <button class="music-play-btn" type="button" aria-label="播放">
      <svg class="icon-play" viewBox="0 0 24 24" width="18" height="18" fill="currentColor">
        <path d="M8 5v14l11-7z" />
      </svg>
      <svg class="icon-pause" viewBox="0 0 24 24" width="18" height="18" fill="currentColor">
        <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z" />
      </svg>
    </button>
  </div>
  <audio class="music-audio" preload="none">
    <source src={url} type="audio/mpeg" />
  </audio>
</div>
