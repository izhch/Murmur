---
interface Props {
  title: string;
  artist: string;
  url: string;
  cover?: string;
}
const { title, artist, url, cover } = Astro.props;
---

<div class="music-player" data-music-url={url}>
  <div class="music-cover-area">
    {cover ? <img src={cover} alt={title} loading="lazy" class="music-cover-img" /> : null}
  </div>
  <div class="music-info">
    <div class="music-text">
      <div class="music-title">{title}</div>
      <div class="music-artist">{artist}</div>
    </div>
    <button class="music-play-btn" type="button" aria-label="播放">
      <svg class="icon-play" xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 512 512">
        <path d="M448 256c0-106-86-192-192-192S64 150 64 256s86 192 192 192 192-86 192-192z" fill="none" stroke="transparent" stroke-miterlimit="10" stroke-width="10"/>
        <path d="M216.32 334.44l114.45-69.14a10.89 10.89 0 000-18.6l-114.45-69.14a10.78 10.78 0 00-16.32 9.31v138.26a10.78 10.78 0 0016.32 9.31z" fill="currentColor" stroke="none"/>
      </svg>
      <svg class="icon-pause" xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 512 512">
        <path d="M448 256c0-106-86-192-192-192S64 150 64 256s86 192 192 192 192-86 192-192z" fill="none" stroke="transparent" stroke-miterlimit="10" stroke-width="10"/>
        <path d="M208 192v128M304 192v128" fill="none" stroke="currentColor" stroke-linecap="round" stroke-miterlimit="10" stroke-width="36"/>
      </svg>
      <svg class="icon-loading" xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 512 512">
        <path d="M448 256c0-106-86-192-192-192S64 150 64 256s86 192 192 192 192-86 192-192z" fill="none" stroke="transparent" stroke-miterlimit="10" stroke-width="10"/>
        <circle r="90" cy="256" cx="256" fill="currentColor" stroke="none"/>
      </svg>
    </button>
    <div class="music-progress-area">
      <span class="music-time-current">0:00</span>
      <div class="music-progress-bar">
        <div class="music-progress-fill"></div>
      </div>
      <span class="music-time-total">0:00</span>
    </div>
  </div>
  <audio class="music-audio" preload="none"><source src={url} type="audio/mpeg" /></audio>
</div>

<script is:inline>
  (function() {
    function extractDominantColor(img, callback) {
      var canvas = document.createElement('canvas');
      var ctx = canvas.getContext('2d');
      canvas.width = 32;
      canvas.height = 32;
      try {
        ctx.drawImage(img, 0, 0, 32, 32);
        var data = ctx.getImageData(0, 0, 32, 32).data;
        var r = 0, g = 0, b = 0, count = 0;
        for (var i = 0; i < data.length; i += 16) {
          r += data[i];
          g += data[i + 1];
          b += data[i + 2];
          count++;
        }
        callback(Math.round(r / count), Math.round(g / count), Math.round(b / count));
      } catch (e) {
        callback(200, 200, 200);
      }
    }

    function generateGradient(r, g, b) {
      return 'linear-gradient(to right, ' +
        'rgba(' + r + ',' + g + ',' + b + ',0.6) 0%, ' +
        'rgba(' + r + ',' + g + ',' + b + ',0.5) 25%, ' +
        'rgba(' + r + ',' + g + ',' + b + ',0.35) 50%, ' +
        'rgba(' + r + ',' + g + ',' + b + ',0.18) 70%, ' +
        'rgba(' + r + ',' + g + ',' + b + ',0.08) 85%, ' +
        'rgba(' + r + ',' + g + ',' + b + ',0) 100%)';
    }

    function applyGradient(player) {
      var coverImg = player.querySelector('.music-cover-img');
      var infoArea = player.querySelector('.music-info');
      if (!coverImg || !infoArea) return;

      var apply = function() {
        extractDominantColor(coverImg, function(r, g, b) {
          infoArea.style.background = generateGradient(r, g, b);
        });
      };

      if (coverImg.complete && coverImg.naturalWidth > 0) {
        apply();
      } else {
        coverImg.addEventListener('load', apply);
        coverImg.addEventListener('error', function() {
          infoArea.style.background = 'linear-gradient(to right, rgba(232,232,232,0.6) 0%, rgba(232,232,232,0.5) 25%, rgba(232,232,232,0.35) 50%, rgba(232,232,232,0.18) 70%, rgba(232,232,232,0.08) 85%, rgba(232,232,232,0) 100%)';
        });
      }
    }

    function initPlayButton(player) {
      var btn = player.querySelector('.music-play-btn');
      var audio = player.querySelector('.music-audio');
      if (!btn || !audio) return;

      btn.addEventListener('click', function(e) {
        e.stopPropagation();
        var isPlaying = player.classList.contains('playing');
        if (isPlaying) {
          audio.pause();
          player.classList.remove('playing');
        } else {
          document.querySelectorAll('.music-player.playing').forEach(function(p) {
            p.classList.remove('playing');
            var a = p.querySelector('.music-audio');
            if (a) a.pause();
          });
          player.classList.add('loading');
          var playPromise = audio.play();
          if (playPromise !== undefined) {
            playPromise.then(function() {
              player.classList.remove('loading');
              player.classList.add('playing');
            }).catch(function() {
              player.classList.remove('loading');
            });
          } else {
            player.classList.remove('loading');
            player.classList.add('playing');
          }
        }
      });

      audio.addEventListener('ended', function() {
        player.classList.remove('playing');
      });

      var progressBar = player.querySelector('.music-progress-bar');
      var progressFill = player.querySelector('.music-progress-fill');
      var currentTimeEl = player.querySelector('.music-time-current');
      var totalTimeEl = player.querySelector('.music-time-total');

      function formatTime(sec) {
        if (isNaN(sec)) return '0:00';
        var m = Math.floor(sec / 60);
        var s = Math.floor(sec % 60);
        return m + ':' + (s < 10 ? '0' : '') + s;
      }

      audio.addEventListener('timeupdate', function() {
        if (!audio.duration) return;
        var pct = (audio.currentTime / audio.duration) * 100;
        if (progressFill) progressFill.style.width = pct + '%';
        if (currentTimeEl) currentTimeEl.textContent = formatTime(audio.currentTime);
        if (totalTimeEl) totalTimeEl.textContent = formatTime(audio.duration);
      });

      audio.addEventListener('loadedmetadata', function() {
        if (totalTimeEl) totalTimeEl.textContent = formatTime(audio.duration);
      });

      if (progressBar) {
        progressBar.addEventListener('click', function(e) {
          e.stopPropagation();
          var rect = progressBar.getBoundingClientRect();
          var pct = (e.clientX - rect.left) / rect.width;
          if (audio.duration) {
            audio.currentTime = pct * audio.duration;
          }
        });
      }

      audio.addEventListener('canplay', function() {
        if (player.classList.contains('loading')) {
          player.classList.remove('loading');
          player.classList.add('playing');
        }
      });
    }

    document.querySelectorAll('.music-player').forEach(function(player) {
      applyGradient(player);
      initPlayButton(player);
    });
  })();
</script>
