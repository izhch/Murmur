---
// 浮动按钮组件：暗色模式切换 + 返回顶部
// 浮动按钮容器布局
// - fixed 定位，right: 2%, bottom: 4%
// - 按钮尺寸 36x36，圆角 4px，半透明背景
// - 滚动超过视口一半时显示，否则隐藏
// - z-index: 11
---

<!-- 浮动按钮容器：初始透明且不可交互，滚动后显示 -->
<div id="misc" class="fixed right-[2%] bottom-[4%] z-[11] flex flex-col gap-[15px] opacity-0 pointer-events-none transition-opacity duration-300">
  <!-- 暗色模式切换按钮 -->
  <button
    type="button"
    id="appearance"
    class="group flex h-9 w-9 cursor-pointer items-center justify-center rounded-[4px] bg-black/[0.065] transition-colors hover:bg-black/[0.12] dark:bg-black/[0.1] dark:hover:bg-black/[0.18]"
    aria-label="切换暗色模式"
  >
    <!-- 亮色模式：月亮图标 -->
    <svg class="moon-icon h-[22px] w-[22px] text-[#777] opacity-50 transition-opacity group-hover:opacity-80 dark:hidden" viewBox="0 0 24 24" fill="currentColor">
      <path d="M12 3c.132 0 .263 0 .393 0a7.5 7.5 0 0 0 7.92 12.446a9 9 0 1 1 -8.313 -12.454z" />
    </svg>
    <!-- 暗色模式：太阳图标 -->
    <svg class="sun-icon hidden h-[14px] w-[14px] text-[#ccc] opacity-50 transition-opacity group-hover:opacity-80 dark:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="5" />
      <line x1="12" y1="1" x2="12" y2="3" />
      <line x1="12" y1="21" x2="12" y2="23" />
      <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
      <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
      <line x1="1" y1="12" x2="3" y2="12" />
      <line x1="21" y1="12" x2="23" y2="12" />
      <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
      <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
    </svg>
  </button>

  <!-- 返回顶部按钮 -->
  <button
    type="button"
    id="totop"
    class="flex h-9 w-9 cursor-pointer items-center justify-center rounded-[4px] bg-black/[0.065] transition-colors hover:bg-black/[0.12] dark:bg-black/[0.1] dark:hover:bg-black/[0.18]"
    aria-label="返回顶部"
  >
    <svg class="h-[18px] w-[18px] text-[#777] opacity-50 dark:text-[#ccc]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <line x1="12" y1="19" x2="12" y2="5" />
      <polyline points="5 12 12 5 19 12" />
    </svg>
  </button>
</div>
