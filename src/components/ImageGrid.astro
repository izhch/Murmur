---
// 九宫格图片组件
// grid-1 horizontal: 66% 宽；grid-1 vertical/square: 50% 宽
// grid-2: 66% 宽，2 列；grid-3: calc(100% - 50px) 宽，3 列
// 支持点击放大查看

// 定义图片网格属性
interface Props {
  // 图片 URL 数组
  images: string[];
}

// 从 props 解构图片数组，并计算数量
const { images } = Astro.props;
const count = images.length;

// grid-3 宽度为 calc(100% - 50px)，即减去一个头像偏移量
const wrapperClass =
  count === 1
    ? 'w-2/3'
    : count === 2
      ? 'w-2/3 grid-cols-2'
      : 'w-[calc(100%-50px)] grid-cols-3';
---

{count > 0 && (
  <!-- 图片网格容器：绑定完整图片数组供查看器使用 -->
  <div
    class={`image-grid mt-2 grid gap-1 ${wrapperClass}`}
    data-images={JSON.stringify(images)}
  >
    {images.map((src, i) => (
      <!-- 单张缩略图：单图为 4:3，多图为正方形 -->
      <div
        class={`image-thumb relative cursor-zoom-in overflow-hidden bg-moments-divider dark:bg-moments-dark-divider ${count === 1 ? 'aspect-[4/3]' : 'aspect-square'}`}
        data-index={i}
      >
        <img
          src={src}
          alt={`图片 ${i + 1}`}
          class="image-thumb-img absolute left-0 top-0 h-full w-full object-cover"
          loading="lazy"
        />
        <!-- 图片加载失败占位符 -->
        <div class="image-error-placeholder hidden absolute inset-0 items-center justify-center bg-moments-divider dark:bg-moments-dark-divider">
          <svg class="h-8 w-8 text-moments-sub dark:text-moments-dark-sub opacity-50" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <rect x="3" y="3" width="18" height="18" rx="2" />
            <circle cx="8.5" cy="8.5" r="1.5" />
            <path d="M21 15l-5-5L5 21" />
          </svg>
        </div>
      </div>
    ))}
  </div>
)}