---
interface Props {
  images: string[];
}

const { images } = Astro.props;
const count = images.length;

let gridClass = 'grid-3';
if (count === 1) gridClass = 'grid-1';
else if (count === 2) gridClass = 'grid-2';
else if (count === 4) gridClass = 'grid-4';
---

<div class={`post-content-gallery ${gridClass}`}>
  {images.map((src, i) => (
    <figure class="gallery-thumbnail">
      <img
        class="thumbnail-image"
        src={src}
        alt={`图片 ${i + 1}`}
        loading="lazy"
        data-index={i}
        data-images={encodeURIComponent(JSON.stringify(images))}
      />
    </figure>
  ))}
</div>
