---
import ImageGrid from './ImageGrid.astro';
import MusicPlayer from './MusicPlayer.astro';
import VideoPlayer from './VideoPlayer.astro';
import { formatRelativeTime } from '../utils';

interface Props {
  moment: {
    id: string;
    date: string;
    content: string;
    Content?: any;
    images?: string[];
    music?: { title: string; artist: string; url: string; cover?: string };
    video?: { url: string; cover?: string };
    location?: string;
    author: { name: string; avatar: string };
  };
}

const { moment, class: className = '' } = Astro.props;
const ContentComponent = moment.Content;

// 计算纯文本长度（用于判断是否需要折叠）
const plainText = (moment.content || '').replace(/<[^>]*>/g, '').replace(/\s/g, '');
const needsFold = plainText.length > 200;

// 提取纯文本预览（去掉 HTML 标签和 Markdown 标记，只保留文字）
function extractPlainTextPreview(raw: string, maxLen: number): string {
  const text = raw
    .replace(/<[^>]*>/g, '')
    .replace(/#{1,6}\s+/g, '')
    .replace(/\*\*(.+?)\*\*/g, '$1')
    .replace(/\*(.+?)\*/g, '$1')
    .replace(/`(.+?)`/g, '$1')
    .replace(/```[\s\S]*?```/g, '')
    .replace(/>\s?/g, '')
    .replace(/[-*+]\s/g, '')
    .replace(/\[(.+?)\]\(.+?\)/g, '$1')
    .replace(/---+/g, '')
    .replace(/\s+/g, ' ')
    .trim();
  if (text.length <= maxLen) return text;
  return text.slice(0, maxLen);
}

const previewText = needsFold ? extractPlainTextPreview(moment.content, 200) : '';
---

<article class={className} data-moment-id={moment.id}>
  <div class="post-avatar">
    <img src={moment.author.avatar} loading="lazy" draggable="false" alt="" />
  </div>
  <div class="post-main">
    <header class="post-header">
      <div class="post-title">{moment.author.name}</div>
    </header>
    <section class="post-content">
      {needsFold ? (
        <span class="more-area">
          <span class="more-preview">{previewText}</span>
          <span class="more-content">
            {ContentComponent ? <ContentComponent /> : <Fragment set:html={moment.content} />}
          </span>
          <span class="more-ellipsis">...</span>
          <span class="more-btn more">展开</span>
          <span class="more-btn less">收起</span>
        </span>
      ) : (
        ContentComponent ? <ContentComponent /> : <Fragment set:html={moment.content} />
      )}
    </section>
    {moment.images && moment.images.length > 0 && <ImageGrid images={moment.images} />}
    {moment.music && <MusicPlayer {...moment.music} />}
    {moment.video && <VideoPlayer {...moment.video} />}
    <footer class="post-footer">
      <div class="post-info">
        <span>{formatRelativeTime(moment.date)}</span>
        {moment.location && <span class="post-location">{moment.location}</span>}
      </div>
      <div class="post-fun">
        <div class="fun-ico"></div>
        <div class="fun-box"><div class="fun-btn like allow">赞</div><div class="fun-btn comment allow">评论</div></div>
      </div>
    </footer>
  </div>
</article>
