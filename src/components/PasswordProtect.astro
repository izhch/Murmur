---
// 密码保护组件：前端实现的简单密码保护（防君子不防小人）
// 使用 SHA256 哈希存储，不直接暴露明文密码

interface Props {
  // 文章唯一标识
  momentId: string;
  // 密码 SHA256 哈希值（从前端传入，用于验证）
  passwordHash: string;
}

const { momentId, passwordHash } = Astro.props;
---

<form class="password-form" data-moment-id={momentId} data-password-hash={passwordHash} onsubmit="return false;">
  <div class="password-input-group">
    <input
      type="password"
      class="password-field"
      inputmode="numeric"
      placeholder="密码"
      autocomplete="off"
    />
    <label class="password-label">输入密码显示内容</label>
    <hr class="password-line" />
  </div>
  <div class="password-submit-area">
    <button type="button" class="password-btn">提交</button>
  </div>
</form>

<style>
  /* 密码保护表单容器：固定 333.33x126px */
  .password-form {
    position: relative;
    width: 333.33px;
    height: 126px;
    margin-top: 10px;
    padding: 12px;
    background-color: #f7f7f7;
    background-image: repeating-linear-gradient(
      135deg,
      #f2f2f2 0,
      #f2f2f2 15px,
      transparent 0,
      transparent 30px
    );
    background-position: 0 0;
    background-repeat: repeat;
    border: 1px solid #ffffff;
    transition: background-position 0.4s cubic-bezier(0.4, 0, 0.2, 1),
                border-color 0.15s cubic-bezier(0.4, 0, 0.2, 1);
    /* 移动端：占满父容器宽度，高度保持 126px */
    max-width: 100%;
    box-sizing: border-box;
  }

  /* 聚焦时斜条纹向左移动 -20px，产生动画效果 */
  .password-form:focus-within {
    background-position: -20px 0;
    border-color: #576b95;
  }

  /* 暗色模式 */
  html.darkmode .password-form {
    background-color: #363636;
    background-image: repeating-linear-gradient(
      135deg,
      #3a3a3a 0,
      #3a3a3a 15px,
      transparent 0,
      transparent 30px
    );
    border-color: #2c2c2c;
  }

  html.darkmode .password-form:focus-within {
    border-color: #7d90a9;
  }

  /* 输入框组 */
  .password-input-group {
    position: relative;
  }

  /* 密码输入框 */
  .password-field {
    width: 100%;
    padding: 24px 0 6px;
    border: none;
    background: transparent;
    font-size: 16px;
    font-weight: 700;
    line-height: 22px;
    letter-spacing: 3px;
    color: #576b95;
    outline: none;
  }

  .password-field::placeholder {
    color: transparent;
  }

  html.darkmode .password-field {
    color: #7d90a9;
  }

  /* 浮动标签 */
  .password-label {
    position: absolute;
    top: 23px;
    left: 0;
    font-size: 16px;
    font-weight: 400;
    line-height: 22px;
    color: #191919;
    pointer-events: none;
    transform-origin: left top;
    transition: transform 0.15s cubic-bezier(0.4, 0, 0.2, 1),
                color 0.15s cubic-bezier(0.4, 0, 0.2, 1);
  }

  html.darkmode .password-label {
    color: #eaeaea;
  }

  /* 输入框聚焦或有内容时，标签上移缩小 */
  .password-field:focus ~ .password-label,
  .password-field:not(:placeholder-shown) ~ .password-label {
    transform: scale(0.857) translate(0, -24px);
    color: #b2b2b2;
  }

  /* 底部指示线 */
  .password-line {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 2px;
    margin: 0;
    border: none;
    background: #576b95;
    transform: scaleX(0);
    opacity: 0;
    transition: transform 0.15s cubic-bezier(0.4, 0, 0.2, 1),
                opacity 0.15s cubic-bezier(0.4, 0, 0.2, 1);
  }

  html.darkmode .password-line {
    background: #7d90a9;
  }

  /* 输入框聚焦或有内容时，指示线展开 */
  .password-field:focus ~ .password-line,
  .password-field:not(:placeholder-shown) ~ .password-line {
    transform: scaleX(1);
    opacity: 1;
  }

  /* 提交按钮区域 */
  .password-submit-area {
    margin-top: 12px;
    text-align: right;
  }

  /* 提交按钮 */
  .password-btn {
    display: inline-block;
    padding: 6px 12px;
    border: none;
    background: #f7f7f7;
    font-size: 16px;
    font-weight: 500;
    line-height: 24px;
    color: #576b95;
    cursor: pointer;
    transition: opacity 0.2s;
  }

  .password-btn:hover {
    opacity: 0.8;
  }

  html.darkmode .password-btn {
    background: #363636;
    color: #7d90a9;
  }

  /* 错误状态：表单抖动 */
  .password-form.error {
    animation: shake 0.3s ease-in-out;
  }

  /* 抖动动画 */
  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    20%, 60% { transform: translateX(-4px); }
    40%, 80% { transform: translateX(4px); }
  }
</style>
