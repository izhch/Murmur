---
// 赞/评论弹出菜单组件（fun-box）

// 定义菜单属性：绑定到对应动态的 id
interface Props {
  momentId: string;
}

// 从 props 解构动态 id
const { momentId } = Astro.props;
---

<!-- 菜单根节点：作为 trigger 与 popover 的定位上下文 -->
<div class="relative" data-menu-root={momentId}>
  <!-- 触发按钮：两个小圆点图标 -->
  <button
    type="button"
    class="menu-trigger flex h-[20px] w-[30px] items-center justify-center rounded-[4px] bg-moments-aside dark:bg-moments-dark-aside"
    aria-label="更多操作"
  >
    <img src="/icons/post.fun.ico.light.svg" alt="" class="menu-ico-light h-[20px] w-[20px]" />
    <img src="/icons/post.fun.ico.dark.svg" alt="" class="menu-ico-dark hidden h-[20px] w-[20px]" />
  </button>

  <!-- 弹出菜单：右侧展开，垂直居中 -->
  <div
    class="menu-popover absolute top-1/2 right-full z-30 hidden"
    style="transform: translateY(-50%); margin-right: 10px;"
    role="menu"
  >
    <div class="menu-popover-inner whitespace-nowrap rounded-[4px] bg-moments-menu dark:bg-moments-dark-menu" style="padding: 8px 0px; height: 40px; box-sizing: border-box;">
      <div class="flex items-center h-full">
        <!-- 点赞按钮 -->
        <div
          class="menu-action-like relative h-[24px] text-[16px] leading-[24px] text-white cursor-pointer"
          style="margin: 0 20px; padding-left: 22px; background-image: url(/icons/post.fun.btn.like.svg); background-position: 0 50%; background-repeat: no-repeat;"
          data-action="like"
          data-liked="0"
        >
          赞
        </div>
        <!-- 竖线分隔 -->
        <div class="w-[1px] h-[16px] bg-white/30"></div>
        <!-- 评论按钮 -->
        <div
          class="menu-action-comment h-[24px] text-[16px] leading-[24px] text-white cursor-pointer"
          style="margin: 0 20px; padding-left: 22px; background-image: url(/icons/post.fun.btn.comment.svg); background-position: 0 50%; background-repeat: no-repeat;"
          data-action="comment"
        >
          评论
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  /* 暗色模式下切换菜单触发图标 */
  html.darkmode .menu-ico-light {
    display: none;
  }
  html.darkmode .menu-ico-dark {
    display: block;
  }

  /* 菜单弹出框初始状态：透明并略向右偏移 */
  .menu-popover-inner {
    opacity: 0;
    transform: translateX(5px);
    transition: all 0.3s ease;
  }

  /* 菜单显示时：淡入并从右向左滑入 */
  .menu-popover:not(.hidden) .menu-popover-inner {
    opacity: 1;
    transform: translateX(0px);
    animation: funbox-anim 0.3s ease forwards;
  }

  /* 菜单弹出动画关键帧 */
  @keyframes funbox-anim {
    0% {
      opacity: 0;
      transform: translateX(5px);
    }
    100% {
      opacity: 1;
      transform: translateX(0px);
    }
  }
</style>